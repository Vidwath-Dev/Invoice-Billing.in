<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - {{invoice.invoiceNumber}}</title>
    <link rel="stylesheet" href="/css/print-invoice.css"> <!-- Include your CSS for styling -->
    <style>
        /* Add styles for printing */
        @media print {
            body {
                -webkit-print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Invoice Number:{{invoice._id}}</h1>
        <p><strong>Date:</strong> {{invoice.createdAt}}</p>
        <p><strong>Email:</strong> {{invoice.userEmail}}</p>
        <h2>Items:</h2>
        <ul>
            {{#each invoice.items}}
                <li>
                    {{this.description}} - Quantity: {{this.quantity}} - Price: ${{this.price}}
                </li>
            {{/each}}
        </ul>
        <h3>Total Amount: ${{invoice.totalAmount}}</h3>
        <button onclick="window.print()">Print Invoice</button> <!-- Button to trigger print -->
    </div>
    <div>
        <a href="/logout" class="btn">Logout</a>
    </div>
</body>
</html>